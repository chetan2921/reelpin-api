# Groq API (transcription + LLM extraction)
GROQ_API_KEY=your_groq_api_key_here

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Pinecone (vector embeddings for RAG search)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=reelmind

# Supabase (PostgreSQL database)
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Worker loop
WORKER_POLL_INTERVAL_SECONDS=3
WORKER_RECOVERY_INTERVAL_SECONDS=60
WORKER_HEARTBEAT_INTERVAL_SECONDS=15
WORKER_STALE_JOB_MINUTES=20
USER_SUBMISSION_LIMIT_PER_HOUR=20
USER_ACTIVE_JOB_LIMIT=4
ADMIN_ALERT_USER_ID=
ADMIN_ALERT_COOLDOWN_MINUTES=60
ADMIN_DASHBOARD_KEY=replace_with_a_long_random_string
WORKER_CONCURRENCY=2
WORKER_INSTAGRAM_CONCURRENCY=1
WORKER_TIKTOK_CONCURRENCY=1
WORKER_YOUTUBE_CONCURRENCY=2
WORKER_WEB_CONCURRENCY=1

# Legacy Redis queue setting, not required for the current database-backed worker
REDIS_URL=redis://localhost:6379/0

# Firebase Cloud Messaging
FIREBASE_SERVICE_ACCOUNT_PATH=/absolute/path/to/firebase-adminsdk.json
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account", ...}

# Authenticated download cookie slots
# Put your primary cookie in ACTIVE and your standby cookie in BACKUP.
# Use either *_COOKIE_DATA_BASE64, *_COOKIE_DATA, or *_COOKIES_FILE.
INSTAGRAM_ACTIVE_COOKIES_FILE=/absolute/path/to/instagram-active-cookies.txt
INSTAGRAM_BACKUP_COOKIES_FILE=/absolute/path/to/instagram-backup-cookies.txt
INSTAGRAM_TERTIARY_COOKIES_FILE=/absolute/path/to/instagram-tertiary-cookies.txt
INSTAGRAM_ACTIVE_COOKIE_DATA=
INSTAGRAM_ACTIVE_COOKIE_DATA_BASE64=
INSTAGRAM_BACKUP_COOKIE_DATA=
INSTAGRAM_BACKUP_COOKIE_DATA_BASE64=
INSTAGRAM_TERTIARY_COOKIE_DATA=
INSTAGRAM_TERTIARY_COOKIE_DATA_BASE64=
YOUTUBE_ACTIVE_COOKIE_DATA=
YOUTUBE_ACTIVE_COOKIE_DATA_BASE64=
YOUTUBE_BACKUP_COOKIE_DATA=
YOUTUBE_BACKUP_COOKIE_DATA_BASE64=
TIKTOK_ACTIVE_COOKIE_DATA=
TIKTOK_ACTIVE_COOKIE_DATA_BASE64=
TIKTOK_BACKUP_COOKIE_DATA=
TIKTOK_BACKUP_COOKIE_DATA_BASE64=
YTDLP_ACTIVE_COOKIE_DATA=
YTDLP_ACTIVE_COOKIE_DATA_BASE64=
YTDLP_BACKUP_COOKIE_DATA=
YTDLP_BACKUP_COOKIE_DATA_BASE64=

# Local development only
YTDLP_COOKIES_FROM_BROWSER=chrome
